# ╔══════════════════════════════════════════════════════════════╗
# ║  DarkPool.trade — Environment Variables                     ║
# ║  Copy to .env and fill in your keys                         ║
# ║  See: keys breakdown at bottom for what each does           ║
# ╚══════════════════════════════════════════════════════════════╝

# ── REQUIRED FOR DEMO (minimum 1 key) ───────────────────────
# AI features: news analysis + Telegram intent extraction
# Without it: agent uses hardcoded mock signals, bot uses keyword parser
# Get from: https://openrouter.ai/settings/keys (preferred — multi-model access)
OPENROUTER_API_KEY=
# Model to use (default: openai/gpt-4o-mini)
# Recommended: openai/gpt-4o-mini (~$0.40/M tokens avg, native JSON mode, fast)
# Alternatives: google/gemini-2.0-flash-001, openai/gpt-4o, anthropic/claude-3.5-haiku
OPENROUTER_MODEL=openai/gpt-4o-mini
# Fallback: direct OpenAI (used if OPENROUTER_API_KEY is not set)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── BLOCKCHAIN RPCs ─────────────────────────────────────────
# Polygon testnet RPC for contract deployment + chain listener
# Without it: use Hardhat local network (contracts still deploy/test)
# Get from: https://dashboard.alchemy.com (free tier)
ALCHEMY_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY

# Solana devnet RPC for Anchor program + DFlow settlement
# Default works out of the box (public devnet endpoint)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Sepolia RPC for Alkahest deployment (where Alkahest lives)
# Default works out of the box (public endpoint)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ── WALLET PRIVATE KEYS ────────────────────────────────────
# Signs contract deploy transactions on Sepolia/Mumbai
# Without it: can't deploy to testnet (Hardhat local still works)
# Generate: any Ethereum wallet, export private key (0x... format)
DEPLOYER_PRIVATE_KEY=

# Signs settlement transactions (hot wallet that calls recordAndFulfillMatch)
# Without it: settler can't call contracts on-chain (matching still runs in-memory)
# Generate: any Ethereum private key (0x... format)
MATCHING_ENGINE_PRIVATE_KEY=

# Signs Polymarket CLOB orders for iceberg execution
# Without it: iceberg queue simulates fills
# Generate: any Polygon wallet private key
EXECUTION_PRIVATE_KEY=

# TRON wallet for contract deployment + tx signing
# Without it: deploy via TronIDE manually
# Generate: TronLink wallet, export hex (NO 0x prefix)
# Fund from: https://nileex.io/join/getJoinPage
TRON_PRIVATE_KEY=

# Filecoin calibnet wallet for Synapse SDK storage
# Without it: agent storage falls back to in-memory (local CIDs)
# Generate: MetaMask configured for Filecoin Calibration (0x... format)
# Fund from: https://faucet.calibnet.chainsafe-fil.io
FILECOIN_PRIVATE_KEY=

# ── CONTRACT ADDRESSES (filled after deploy) ───────────────
# Run: cd contracts && npx hardhat run scripts/deploy.js
# Then paste the printed addresses here
DARK_POOL_ARBITER_ADDRESS=
MOCK_USDC_ADDRESS=
ALKAHEST_ADDRESS=
DARK_POOL_TRON_ADDRESS=
SOLANA_PROGRAM_ID=

# ── TELEGRAM BOT ────────────────────────────────────────────
# Powers the Telegram RFQ bot interface
# Without it: no Telegram bot (show conversation mockup instead)
# Get from: message @BotFather on Telegram -> /newbot
TELEGRAM_BOT_TOKEN=

# ── NEWS AGENT ──────────────────────────────────────────────
# Real-time news headlines for the trading agent
# Without it: agent uses 2 hardcoded mock articles (Fed + BTC)
# Get from: https://newsapi.org/register (free tier: 100 req/day)
NEWSAPI_KEY=

# ── POLYMARKET CLOB ─────────────────────────────────────────
# Real iceberg order execution on Polymarket's order book
# Get from: derive via SDK — client.createOrDeriveApiKey() (needs Polygon wallet)
# Docs: https://docs.polymarket.com/trading/overview
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# ── TRON CONFIG ─────────────────────────────────────────────
# TRON network endpoint (Nile testnet)
TRON_FULL_HOST=https://nile.trongrid.io

# Receives x402-TRON micropayments (any TRON Nile address)
# Without it: x402 TRON middleware disabled, endpoint works without payment gate
TRON_RECEIVER_ADDRESS=

# ── SOLANA x402 ─────────────────────────────────────────────
# Receives x402 Solana micropayments (any Solana devnet address)
# Without it: x402 Solana middleware disabled, endpoint works without payment gate
SOLANA_RECEIVER_WALLET=

# ── INFRASTRUCTURE ──────────────────────────────────────────
# Redis for order book persistence (optional — in-memory works for demo)
REDIS_URL=redis://localhost:6379

# Backend server port
PORT=3001

# Environment
NODE_ENV=development

# Frontend -> Backend connection
NEXT_PUBLIC_API_URL=http://localhost:3001

# ╔══════════════════════════════════════════════════════════════╗
# ║  QUICK REFERENCE                                            ║
# ║                                                             ║
# ║  ZERO KEYS:  Everything works with mocks (tests pass,      ║
# ║              dashboard loads, orders match in-memory)       ║
# ║                                                             ║
# ║  1 KEY:      OPENROUTER_API_KEY = real AI features for demo  ║
# ║                                                             ║
# ║  FULL DEMO:  OPENROUTER_API_KEY + ALCHEMY_RPC_URL +        ║
# ║              DEPLOYER_PRIVATE_KEY + TELEGRAM_BOT_TOKEN +    ║
# ║              NEWSAPI_KEY + TRON_PRIVATE_KEY +               ║
# ║              FILECOIN_PRIVATE_KEY +                         ║
# ║              MATCHING_ENGINE_PRIVATE_KEY                    ║
# ╚══════════════════════════════════════════════════════════════╝
