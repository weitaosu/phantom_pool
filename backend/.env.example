# Backend .env — copy from root .env.example for full docs
# Or just symlink: ln -s ../.env .env

# Required for AI features (pick one)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Fallback (used if OPENROUTER_API_KEY not set)
OPENAI_API_KEY=

# Blockchain RPCs
ALCHEMY_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Wallet keys
DEPLOYER_PRIVATE_KEY=
MATCHING_ENGINE_PRIVATE_KEY=
EXECUTION_PRIVATE_KEY=
TRON_PRIVATE_KEY=
FILECOIN_PRIVATE_KEY=

# Contract addresses (after deploy)
DARK_POOL_ARBITER_ADDRESS=
MOCK_USDC_ADDRESS=
ALKAHEST_ADDRESS=
DARK_POOL_TRON_ADDRESS=
SOLANA_PROGRAM_ID=

# Telegram bot
TELEGRAM_BOT_TOKEN=

# News agent
NEWSAPI_KEY=

# Polymarket CLOB
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# TRON
TRON_FULL_HOST=https://nile.trongrid.io
TRON_RECEIVER_ADDRESS=

# Solana x402
SOLANA_RECEIVER_WALLET=

# Infrastructure
REDIS_URL=redis://localhost:6379
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
